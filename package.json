{
  "name": "@bkramer/proton-cli",
  "version": "0.2.0",
  "description": "Unofficial unified Proton CLI (VPN, Authenticator, shared sign-in)",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonkramer/proton-cli.git"
  },
  "bugs": {
    "url": "https://github.com/brandonkramer/proton-cli/issues"
  },
  "homepage": "https://github.com/brandonkramer/proton-cli#readme",
  "author": "Brandon Kramer",
  "keywords": [
    "proton",
    "protonvpn",
    "authenticator",
    "cli",
    "bun",
    "wireguard",
    "totp"
  ],
  "bin": {
    "proton": "./src/index.ts",
    "protonvpn": "./src/bins/protonvpn.ts",
    "protonauth": "./src/bins/protonauth.ts",
    "protondrive": "./src/bins/protondrive.ts",
    "protoncontacts": "./src/bins/protoncontacts.ts",
    "protoncal": "./src/bins/protoncal.ts",
    "protonsettings": "./src/bins/protonsettings.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "src",
    "packages/*/package.json",
    "packages/*/src",
    "packages/*/scripts",
    "scripts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "skills",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "postinstall": "bun run scripts/postinstall.ts",
    "build:captcha": "bun run packages/authenticator/scripts/build-captcha.ts",
    "start": "bun run src/index.ts",
    "proton": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@protontech/authenticator-rust-core": "1.7.2",
    "@protontech/crypto": "^2.1.1",
    "commander": "^14.0.0",
    "ink": "^7.1.1",
    "react": "^19.2.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "typescript": "^5.9.3"
  }
}
