{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "types": ["bun"],
    "paths": {
      "@bkramer/proton-core": ["./packages/core/src/index.ts"],
      "@bkramer/proton-core/*": ["./packages/core/src/*"],
      "@bkramer/proton-vpn": ["./packages/vpn/src/index.ts"],
      "@bkramer/proton-vpn/*": ["./packages/vpn/src/*"],
      "@bkramer/proton-authenticator": ["./packages/authenticator/src/index.ts"],
      "@bkramer/proton-authenticator/*": ["./packages/authenticator/src/*"]
    }
  },
  "include": ["src/**/*", "packages/*/src/**/*", "packages/*/tests/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
