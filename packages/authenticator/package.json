{
  "name": "@proton-cli/authenticator",
  "version": "0.1.0",
  "description": "Proton Authenticator product commands for proton-cli",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
